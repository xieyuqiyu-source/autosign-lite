{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AutoSign Lite",
  "version": "0.1.0",
  "identifier": "cn.xieyuqiyu.autosignlite",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AutoSign Lite",
        "width": 1320,
        "height": 860,
        "resizable": true,
        "minWidth": 1180,
        "minHeight": 820
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
